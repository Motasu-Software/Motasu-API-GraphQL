generator client {
  provider = "prisma-client-js"
  // "native" pour Windows/Dev, "linux-musl" ou "linux-musl-openssl-3.0.x" pour Docker Alpine
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id    String @id @default(uuid())
  email String @unique
  hash  String
  posts Post[]
}

model Post {
  id          String   @id @default(uuid())
  title       String
  description String
  circuit     String
  car         String
  lapTime     String
  author      User     @relation(fields: [authorId], references: [id])
  authorId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
