{
  "compilerOptions": {
    "rootDir": "src",
    "rootDirs": ["src"],
    "outDir": "dist",
    "lib": ["es2020"],
    "target": "es2020",
    "module": "Node16",
    "moduleResolution": "node16",
    "ignoreDeprecations": "6.0",
    "esModuleInterop": true,
    "types": ["node"]
  },
  "include": ["src/**/*"]
}